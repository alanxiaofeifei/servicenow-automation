{
  "name": "@servicenow-automation/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "generate:release-metadata": "../../scripts/generate-release-metadata.sh",
    "package:windows": "pnpm build && pnpm generate:release-metadata && electron-builder --win zip",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@servicenow-automation/adapters": "workspace:*",
    "@servicenow-automation/ai": "workspace:*",
    "@servicenow-automation/core": "workspace:*",
    "@servicenow-automation/kb": "workspace:*",
    "@servicenow-automation/profiles": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "electron": "^35.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.servicenowautomation.operator",
    "productName": "ServiceNow Automation",
    "asar": true,
    "directories": {
      "output": "dist/windows"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../scripts/windows",
        "to": "scripts/windows",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../scripts/local-cdp-bridge.py",
        "to": "scripts/local-cdp-bridge.py"
      },
      {
        "from": "../../docs/field-trial/windows-operator-quickstart.md",
        "to": "docs/windows-operator-quickstart.md"
      },
      {
        "from": "../../docs/releases/windows-v0.1-rc-manual-test.md",
        "to": "docs/windows-v0.1-rc-manual-test.md"
      },
      {
        "from": "../../dist/release/release-metadata.json",
        "to": "release-metadata.json"
      }
    ],
    "win": {
      "target": [
        "zip"
      ],
      "signAndEditExecutable": false
    }
  }
}
